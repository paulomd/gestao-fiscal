# Gerado pelo Actions no deploy automático. Manual: cp .env.example .env
# Registry (minúsculas). Repo: github.com/paulomd/gestao-fiscal
# Imagens: .../backend, .../jsf, .../angular
GHCR_REGISTRY=ghcr.io/paulomd/gestao-fiscal
IMAGE_TAG=latest

# Postgres + Keycloak: sempre no Docker (deploy/docker-compose.yml)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/gestao_fiscal
SPRING_DATASOURCE_USERNAME=gestao
SPRING_DATASOURCE_PASSWORD=ALTERE_ESTA_SENHA

APP_PUBLIC_URL=http://SEU_IP_OU_DOMINIO
KEYCLOAK_PUBLIC_URL=http://SEU_IP_OU_DOMINIO:8180

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=ALTERE_ESTA_SENHA
