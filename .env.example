# Copie para .env e ajuste conforme seu ambiente:
#   cp .env.example .env

# --- Postgres local (padrão em dev: NÃO sobe postgres no Docker) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://host.docker.internal:5432/gestao_fiscal
SPRING_DATASOURCE_USERNAME=gestao
SPRING_DATASOURCE_PASSWORD=gestao123

# Backend/JSF rodando com mvn (fora do Docker), use localhost:
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/gestao_fiscal

# --- Stack completa no Docker (recomendado: ./scripts/start-all.sh) ---
COMPOSE_PROFILES=docker-db
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/gestao_fiscal

# API exposta na porta 8082 (8080 fica livre no host). Via gateway: http://localhost/api
# Logout JSF redireciona para login-jsf (Keycloak com prompt=login)
OAUTH2_POST_LOGOUT_REDIRECT_URI=http://localhost/login-jsf

# Se o build falhar com "parent snapshot does not exist" (cache WSL corrompido):
# DOCKER_BUILDKIT=0
